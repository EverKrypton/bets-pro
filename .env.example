APP_URL=https://bets-pro.vercel.app
NEXT_PUBLIC_APP_URL=https://bets-pro.vercel.app

MONGODB_URI=mongodb+srv://your-mongodb-uri

# OxaPay - DEPOSITS ONLY (auto-withdraw to your wallet)
OXAPAY_MERCHANT_API_KEY=your-oxapay-merchant-key

# Football Data API (free at football-data.org)
FOOTBALL_DATA_API_KEY=your-football-data-key

# BEP20 Admin Wallet - FOR WITHDRAWALS ONLY
# Generate a new wallet for payouts, NEVER use your main wallet
# Export private key from metamask/tronlink and add to Vercel env vars
BEP20_ADMIN_PRIVATE_KEY=your-bep20-private-key
BNB_RPC_URL=https://bsc-dataseed.binance.org/

ADMIN_EMAIL=ever@ever.com
